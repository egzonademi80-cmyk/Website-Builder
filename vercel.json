{
  "version": 2,
  "installCommand": "pnpm install --frozen-lockfile=false",
  "buildCommand": "pnpm --filter @workspace/security-camera-site run build",
  "outputDirectory": "artifacts/security-camera-site/dist/public",
  "framework": null,
  "functions": {
    "api/index.ts": {
      "runtime": "@vercel/node@3",
      "maxDuration": 30
    }
  },
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/index" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "env": {
    "NODE_ENV": "production"
  }
}
